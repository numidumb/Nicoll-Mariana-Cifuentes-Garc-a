Algoritmo ejercicio_25
	// Declaración de variables
    Definir num, i Como Entero;
	
	Escribir "este es un programa para llenar 5 posiciones de un vector"
	
    // Creación de un vector de 5 posiciones
    Dimension num[5];
	
    // Recorrido del vector para mostrar sus elementos
    Para i <- 1 Hasta 5 Con Paso 1 Hacer
        escribir "Ingrese el primer vector"
		leer num[i];
		Escribir num[i];
    Fin Para

FinAlgoritmo
