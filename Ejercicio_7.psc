Algoritmo sin_titulo
// programa para calcular el area de un circulo
	Definir a Como entero
	Definir p Como Real //pi es un numero decimal,, por lo que se define como real
	p = 3.1416; 
	
	Escribir"Ingrese su radio"; // se le solicita al usuario el radio
	Leer a;
	
	Escribir "Su área es: " p*a^2 //se calcula el area con la formula de pi x area a la 2
	
FinAlgoritmo
