Algoritmo ejercicio_24
	// Declaración de variables
    Definir num, i Como Entero;
	
    // Creación de un vector de 5 posiciones
    Dimension num[5];
	
    // Asignación de valores al vector
    num[1] <- 5;
    num[2] <- 10;
    num[3] <- 15;
    num[4] <- 20;
    num[5] <- 25;
	
    // Recorrido del vector para mostrar sus elementos
    Para i <- 1 Hasta 5 Con Paso 1 Hacer
        Escribir num[i];
    Fin Para

FinAlgoritmo
